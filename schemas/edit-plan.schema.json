{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/edit-plan.schema.json",
  "title": "EditPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "document_version",
    "instruction_summary",
    "scope",
    "operations",
    "used_reference_ids",
    "used_evidence_ids",
    "unsupported_claims",
    "warnings",
    "assumptions"
  ],
  "properties": {
    "schema_version": {
      "const": "edit-plan/1.0"
    },
    "document_id": {
      "type": "string",
      "pattern": "^doc_[A-Za-z0-9_-]+$"
    },
    "document_version": {
      "type": "integer",
      "minimum": 1
    },
    "instruction_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_node_ids"
      ],
      "properties": {
        "allowed_node_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "chapter_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "used_reference_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "used_evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "reason"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "maxLength": 2000
          },
          "reason": {
            "type": "string",
            "maxLength": 1000
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "expected_text_hash"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "expected_text_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "locator": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "enum": [
            "page",
            "chapter",
            "section",
            "paragraph",
            "line",
            "figure",
            "table",
            "other"
          ]
        },
        "value": {
          "type": "string",
          "maxLength": 100
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference_ids",
        "evidence_ids",
        "citation_mode",
        "locator"
      ],
      "properties": {
        "type": {
          "const": "citation"
        },
        "reference_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "citation_mode": {
          "enum": [
            "parenthetical",
            "narrative",
            "suppress_author"
          ]
        },
        "locator": {
          "$ref": "#/$defs/locator"
        },
        "prefix": {
          "type": "string",
          "maxLength": 200
        },
        "suffix": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "content_block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "text"
          ],
          "properties": {
            "type": {
              "const": "text"
            },
            "text": {
              "type": "string",
              "maxLength": 20000
            }
          }
        },
        {
          "$ref": "#/$defs/citation"
        }
      ]
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "type",
        "group_id",
        "depends_on",
        "target"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "pattern": "^op_[A-Za-z0-9_-]+$"
        },
        "type": {
          "type": "string"
        },
        "group_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "target": {
          "$ref": "#/$defs/target"
        }
      }
    },
    "operation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "type",
            "group_id",
            "depends_on",
            "target",
            "content",
            "paragraph_style_policy"
          ],
          "properties": {
            "operation_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "insert_paragraph_before",
                "insert_paragraph_after"
              ]
            },
            "group_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target": {
              "$ref": "#/$defs/target"
            },
            "content": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/content_block"
              }
            },
            "paragraph_style_policy": {
              "enum": [
                "inherit_anchor",
                "normal_body",
                "explicit_existing_style"
              ]
            },
            "style_id": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "type",
            "group_id",
            "depends_on",
            "target",
            "start_offset",
            "end_offset",
            "expected_text",
            "replacement_text",
            "format_policy"
          ],
          "properties": {
            "operation_id": {
              "type": "string"
            },
            "type": {
              "const": "replace_text_span"
            },
            "group_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target": {
              "$ref": "#/$defs/target"
            },
            "start_offset": {
              "type": "integer",
              "minimum": 0
            },
            "end_offset": {
              "type": "integer",
              "minimum": 0
            },
            "expected_text": {
              "type": "string",
              "maxLength": 20000
            },
            "replacement_text": {
              "type": "string",
              "maxLength": 20000
            },
            "format_policy": {
              "enum": [
                "inherit_from_start",
                "inherit_from_end",
                "plain_inherit_paragraph"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "type",
            "group_id",
            "depends_on",
            "target",
            "new_text"
          ],
          "properties": {
            "operation_id": {
              "type": "string"
            },
            "type": {
              "const": "replace_plain_paragraph"
            },
            "group_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target": {
              "$ref": "#/$defs/target"
            },
            "new_text": {
              "type": "string",
              "maxLength": 30000
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "type",
            "group_id",
            "depends_on",
            "target"
          ],
          "properties": {
            "operation_id": {
              "type": "string"
            },
            "type": {
              "const": "delete_plain_paragraph"
            },
            "group_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target": {
              "$ref": "#/$defs/target"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "type",
            "group_id",
            "depends_on",
            "target",
            "citation"
          ],
          "properties": {
            "operation_id": {
              "type": "string"
            },
            "type": {
              "const": "insert_citation"
            },
            "group_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target": {
              "$ref": "#/$defs/target"
            },
            "char_offset": {
              "type": "integer",
              "minimum": 0
            },
            "citation": {
              "$ref": "#/$defs/citation"
            }
          }
        }
      ]
    }
  }
}