{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReferencePack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "references",
    "evidence",
    "unresolved_items"
  ],
  "properties": {
    "schema_version": {
      "const": "reference-pack/1.0"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string"
        },
        "given": {
          "type": "string"
        },
        "literal": {
          "type": "string"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_id",
        "metadata",
        "aliases",
        "provenance",
        "verification",
        "citation_ready"
      ],
      "properties": {
        "reference_id": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": [
                "string",
                "null"
              ]
            },
            "title": {
              "type": [
                "string",
                "null"
              ]
            },
            "author": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/person"
              }
            },
            "issued": {
              "type": [
                "object",
                "null"
              ]
            },
            "container-title": {
              "type": [
                "string",
                "null"
              ]
            },
            "volume": {
              "type": [
                "string",
                "null"
              ]
            },
            "issue": {
              "type": [
                "string",
                "null"
              ]
            },
            "page": {
              "type": [
                "string",
                "null"
              ]
            },
            "publisher": {
              "type": [
                "string",
                "null"
              ]
            },
            "DOI": {
              "type": [
                "string",
                "null"
              ]
            },
            "URL": {
              "type": [
                "string",
                "null"
              ]
            },
            "ISBN": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenance": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "verification": {
          "type": "object",
          "required": [
            "identity_status",
            "metadata_status",
            "confidence"
          ],
          "properties": {
            "identity_status": {
              "enum": [
                "verified",
                "probable",
                "unresolved",
                "conflict"
              ]
            },
            "metadata_status": {
              "enum": [
                "verified_by_identifier",
                "verified_by_match",
                "user_supplied",
                "incomplete",
                "conflict"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "resolver": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "citation_ready": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "reference_id",
        "raw_text",
        "classification",
        "locator",
        "provenance",
        "verification"
      ],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "reference_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "raw_text": {
          "type": "string"
        },
        "normalized_claim": {
          "type": [
            "string",
            "null"
          ]
        },
        "classification": {
          "enum": [
            "direct_quote",
            "paraphrase",
            "summary",
            "abstract_summary",
            "note",
            "unknown"
          ]
        },
        "locator": {
          "type": [
            "object",
            "null"
          ]
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenance": {
          "type": "object"
        },
        "verification": {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "enum": [
                "draft",
                "user_supplied",
                "user_verified",
                "source_verified",
                "ready_for_citation"
              ]
            }
          }
        }
      }
    }
  }
}